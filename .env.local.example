# ==================================
# DOCMAGIC ENVIRONMENT CONFIGURATION
# ==================================
# Copy this file to .env.local and fill in your values

# ==========================================
# SUPABASE CONFIGURATION (REQUIRED)
# ==========================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Site URL - IMPORTANT for email verification links!
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# EMAIL CONFIGURATION (For custom emails)
# ==========================================
# Option 1: Use Gmail SMTP (recommended for testing)
# Enable "Less secure apps" or use App Password
# https://myaccount.google.com/apppasswords

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=DocMagic <your-email@gmail.com>

# Alternative naming (also supported)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=DocMagic <your-email@gmail.com>

# ==========================================
# AI CONFIGURATION (REQUIRED)
# ==========================================
# Gemini API - Get from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here

# Mistral API (for Website Builder) - Get from: https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here

# ==========================================
# STRIPE CONFIGURATION (Optional - for payments)
# ==========================================
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs (Create products in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_ID_INDIVIDUAL_MONTHLY=price_your_individual_monthly_here
NEXT_PUBLIC_STRIPE_PRICE_ID_INDIVIDUAL_YEARLY=price_your_individual_yearly_here
NEXT_PUBLIC_STRIPE_PRICE_ID_ORGANIZATION_MONTHLY=price_your_organization_monthly_here
NEXT_PUBLIC_STRIPE_PRICE_ID_ORGANIZATION_YEARLY=price_your_organization_yearly_here

# Set to 'true' to enable Stripe
NEXT_PUBLIC_ENABLE_STRIPE=false

# ==========================================
# IMAGE GENERATION (Optional)
# ==========================================
# Nebius (for Presentations) - Get from: https://tokenfactory.nebius.com/
NEBIUS_API_KEY=your-nebius-api-key-here

# Pexels (for stock images) - Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# ==========================================
# LINKEDIN IMPORT (Optional)
# ==========================================
# RapidAPI - Get from: https://rapidapi.com/
RAPIDAPI_KEY=your-rapidapi-key-here

# OpenAI (alternative) - Get from: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key-here

# ==========================================
# OTHER CONFIGURATION
# ==========================================
NEXTAUTH_SECRET=your-nextauth-secret-here-use-openssl-rand-base64-32
NODE_ENV=development

# ==========================================
# SUPABASE EMAIL SETUP INSTRUCTIONS
# ==========================================
# 
# For email verification to work, you MUST configure Supabase:
#
# 1. Go to Supabase Dashboard → Authentication → Email Templates
#    - Customize the "Confirm signup" template
#    - Make sure it includes {{ .ConfirmationURL }}
#
# 2. Go to Authentication → Providers → Email
#    - Enable "Confirm email" toggle
#    - Enable "Secure email change"
#
# 3. Go to Authentication → URL Configuration
#    - Site URL: http://localhost:3000 (or your production URL)
#    - Redirect URLs: Add these:
#      - http://localhost:3000/auth/callback
#      - https://yourdomain.com/auth/callback
#
# 4. For PRODUCTION, configure custom SMTP:
#    - Go to Project Settings → Authentication → SMTP Settings
#    - Enter your SMTP credentials
#    - This sends emails from your domain instead of Supabase's
#
# ==========================================
